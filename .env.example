# PropTx/AMPRE OData API Token
AMPRE_TOKEN=

# Anthropic API Key (for Expert Analysis)
ANTHROPIC_API_KEY=

# Google Sign-In (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID)
# Type: Web application
# Authorized JavaScript origins: https://www.mississaugainvestor.ca, http://localhost:3000
# Authorized redirect URIs: https://www.mississaugainvestor.ca, http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Supabase (optional — auth works via localStorage fallback)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
