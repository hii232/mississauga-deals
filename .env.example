# PropTx/AMPRE OData API Tokens
AMPRE_TOKEN=
# VOW token (sold/price-history data)
AMPRE_VOW_TOKEN=

# Anthropic API Key (for Expert Analysis + auto-blog)
ANTHROPIC_API_KEY=

# Google Sign-In (Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID)
# Type: Web application
# Authorized JavaScript origins: https://www.mississaugainvestor.ca, http://localhost:3000
# Authorized redirect URIs: https://www.mississaugainvestor.ca, http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Analytics measurement ID (G-XXXXXXX)
NEXT_PUBLIC_GA_ID=

# Supabase (stores leads, saved searches, newsletter subscribers, blog posts;
# auth works via localStorage fallback if absent)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (https://resend.com) — sends ALL outbound email: deal alerts, weekly
# newsletter, lead notifications. Domain must be verified in Resend for
# RESEND_FROM_EMAIL to deliver.
RESEND_API_KEY=
RESEND_FROM_EMAIL="MississaugaInvestor <notifications@mississaugainvestor.ca>"

# Email address that receives a notification when a new lead comes in
LEAD_NOTIFICATION_EMAIL=

# Shared secrets: Vercel Cron auth (alerts/newsletter sends) + admin API/dashboard
CRON_SECRET=
ADMIN_SECRET=

# IndexNow key for search-engine ping on new content (optional)
INDEXNOW_KEY=
